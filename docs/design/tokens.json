{
  "meta": {
    "direction": "2a — Vertical Duel",
    "source": "M0 wireframe pass",
    "appliesFrom": "M0 (optional, spike is unstyled by design) or M1 (recommended)"
  },
  "color": {
    "bgDeep": "#140b07",
    "panelPlayer": "#1c1608",
    "panelPlayerGradientTo": "#241f3d20",
    "panelMonster": "#2a0d17",
    "panelMonsterGradientFrom": "#3b1220",
    "borderGold": "#7a5a22",
    "borderGoldDim": "#4a3a18",
    "accentGold": "#c9a227",
    "accentGoldBright": "#e8c766",
    "danger": "#8b2020",
    "dangerBright": "#c94b4b",
    "textPrimary": "#ede1c3",
    "textDim": "#a89a7a"
  },
  "font": {
    "display": {
      "family": "Cinzel",
      "weights": [500, 700],
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700"
    },
    "body": {
      "family": "EB Garamond",
      "weights": ["400", "400italic"],
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family=EB+Garamond:ital@0;1"
    },
    "mono": {
      "family": "JetBrains Mono",
      "weights": [400, 500, 700],
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700",
      "usage": "target prompt, live input, monster's live-typed text — never substitute, legibility-critical"
    }
  },
  "layout": {
    "outerMaxWidth": 1040,
    "outerPadding": 28,
    "outerBorder": "3px solid var(--borderGold)",
    "outerInsetOutline": "1px solid #3a2a10, offset -8px",
    "panelBorderRadius": 8,
    "panelPadding": "16px 20px",
    "hpBarHeight": 14,
    "hpBarRadius": 7,
    "countdownColumnWidth": 64
  },
  "keyboard": {
    "keySize": [34, 32],
    "keyRadius": 4,
    "keyBaseBg": "rgba(237,225,195,0.06)",
    "keyBaseBorder": "1px solid var(--borderGoldDim)",
    "states": {
      "nextKey": { "bg": "#e8c766", "textColor": "#1c0f0a", "boxShadow": "0 0 10px #e8c76699" },
      "plusOne": { "bg": "rgba(232,199,102,0.55)" },
      "plusTwo": { "bg": "rgba(232,199,102,0.3)" },
      "backspaceOnly": { "note": "off-track: only Backspace uses nextKey styling, all else base" },
      "enterOnly": { "note": "complete: only Enter uses nextKey styling, all else base" }
    }
  }
}
